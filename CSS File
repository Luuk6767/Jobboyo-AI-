CSS-kod (jobboyo.css):
css@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap');

:root {
  --green:   #00c875;
  --bg:      #0a0f0d;
  --bg2:     #111a14;
  --bg3:     #162019;
  --surface: #1a2a1e;
  --border:  rgba(0,200,117,0.18);
  --border2: rgba(255,255,255,0.06);
  --text:    #f0f4f1;
  --muted:   #7a9980;
  --orange:  #ffa032;
  --blue:    #4fa3e0;
  --purple:  #a78bfa;
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }

body {
  font-family:'DM Sans',sans-serif;
  background:var(--bg); color:var(--text);
  line-height:1.7; overflow-x:hidden;
}

a { color:inherit; text-decoration:none; }

@keyframes pulse {
  0%,100% { opacity:.6; transform:translateX(-50%) scale(1); }
  50%      { opacity:1;  transform:translateX(-50%) scale(1.06); }
}
@keyframes blink {
  0%,100% { opacity:1; } 50% { opacity:.25; }
}
@keyframes fadeUp {
  from { opacity:0; transform:translateY(22px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ── NAV ── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  display:flex; align-items:center; justify-content:space-between;
  padding:1rem 2.5rem;
  background:rgba(10,15,13,0.88); backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border2);
}
.nav-logo { display:flex; align-items:center; gap:10px; font-family:'Syne',sans-serif; font-weight:700; font-size:1.2rem; }
.nav-logo-icon { width:32px; height:32px; border-radius:8px; background:var(--green); display:flex; align-items:center; justify-content:center; }
.nav-logo-icon svg { width:18px; height:18px; }
.nav-links { display:flex; gap:2rem; list-style:none; }
.nav-links a { color:var(--muted); font-size:14px; transition:color .2s; }
.nav-links a:hover { color:var(--text); }
.nav-cta { background:var(--green); color:#0a0f0d; border-radius:8px; padding:8px 20px; font-size:14px; font-weight:600; transition:background .2s,transform .15s; }
.nav-cta:hover { background:#00e688; transform:translateY(-1px); }

/* ── HERO ── */
.hero {
  position:relative; min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  text-align:center; padding:8rem 2rem 4rem; overflow:hidden;
}
.hero-glow {
  position:absolute; top:-120px; left:50%; transform:translateX(-50%);
  width:800px; height:800px;
  background:radial-gradient(circle,rgba(0,200,117,0.11) 0%,transparent 70%);
  pointer-events:none; animation:pulse 5s ease-in-out infinite;
}
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(0,200,117,0.1); border:1px solid rgba(0,200,117,0.28);
  border-radius:99px; padding:6px 18px; font-size:13px; color:var(--green);
  margin-bottom:2rem; animation:fadeUp .6s ease both;
}
.hero-badge span { width:6px; height:6px; border-radius:50%; background:var(--green); display:inline-block; animation:blink 2s infinite; }
.hero h1 { font-family:'Syne',sans-serif; font-size:clamp(2.8rem,7vw,5.5rem); font-weight:800; line-height:1.05; letter-spacing:-.02em; margin-bottom:1.5rem; animation:fadeUp .6s ease .1s both; }
.hero h1 em { font-style:normal; color:var(--green); }
.hero > p { font-size:1.15rem; color:var(--muted); max-width:560px; margin:0 auto 2.5rem; font-weight:300; animation:fadeUp .6s ease .2s both; }
.hero-actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; animation:fadeUp .6s ease .3s both; }
.hero-stats { display:flex; gap:3.5rem; margin-top:4rem; animation:fadeUp .6s ease .4s both; }
.hero-stat { text-align:center; }
.hero-stat .num { font-family:'Syne',sans-serif; font-size:2rem; font-weight:700; color:var(--green); display:block; }
.hero-stat .label { font-size:13px; color:var(--muted); }

/* ── BUTTONS ── */
.btn-primary {
  background:var(--green); color:#0a0f0d; border:none; border-radius:10px;
  padding:14px 32px; font-size:15px; font-weight:600; font-family:'DM Sans',sans-serif;
  cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all .2s;
}
.btn-primary:hover { background:#00e688; transform:translateY(-2px); box-shadow:0 8px 28px rgba(0,200,117,.3); }
.btn-secondary { background:transparent; color:var(--text); border:1px solid var(--border2); border-radius:10px; padding:14px 32px; font-size:15px; font-family:'DM Sans',sans-serif; cursor:pointer; transition:all .2s; }
.btn-secondary:hover { border-color:var(--border); background:var(--surface); }

/* ── SECTIONS ── */
section { padding:6rem 2rem; max-width:1100px; margin:0 auto; position:relative; z-index:1; }
.section-tag { display:inline-block; font-size:11px; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--green); margin-bottom:1rem; }
.section-title { font-family:'Syne',sans-serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; line-height:1.15; letter-spacing:-.01em; margin-bottom:1rem; }
.section-lead { font-size:1.05rem; color:var(--muted); max-width:580px; font-weight:300; margin-bottom:3rem; }
.divider { height:1px; background:linear-gradient(to right,transparent,var(--border2),transparent); margin:0 2rem; }

/* ── STEPS ── */
.steps { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:1px; background:var(--border2); border:1px solid var(--border2); border-radius:16px; overflow:hidden; }
.step { background:var(--bg2); padding:2rem; transition:background .2s; }
.step:hover { background:var(--bg3); }
.step-num { font-family:'Syne',sans-serif; font-size:3rem; font-weight:800; color:rgba(0,200,117,0.1); line-height:1; margin-bottom:1rem; }
.step h3 { font-family:'Syne',sans-serif; font-size:1rem; font-weight:600; margin-bottom:.5rem; }
.step p { font-size:14px; color:var(--muted); line-height:1.65; }

/* ── CV SETUP ── */
.cv-setup { display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start; }
.cv-left { display:flex; flex-direction:column; gap:1rem; }
.cv-step-card { background:var(--bg2); border:1px solid var(--border2); border-radius:14px; padding:1.25rem 1.5rem; display:flex; gap:1rem; align-items:flex-start; transition:border-color .2s; }
.cv-step-card:hover { border-color:var(--border); }
.cv-step-num { font-family:'Syne',sans-serif; font-size:.85rem; font-weight:700; color:var(--green); background:rgba(0,200,117,0.1); border:1px solid rgba(0,200,117,0.2); border-radius:6px; padding:3px 10px; flex-shrink:0; margin-top:2px; }
.cv-step-card h4 { font-family:'Syne',sans-serif; font-size:.95rem; font-weight:600; margin-bottom:4px; }
.cv-step-card p { font-size:13px; color:var(--muted); line-height:1.6; }
.cv-right { background:var(--bg2); border:1px solid var(--border2); border-radius:16px; padding:1.75rem; position:sticky; top:6rem; }
.cv-right h3 { font-family:'Syne',sans-serif; font-size:1rem; font-weight:600; margin-bottom:1.25rem; }
.pref-group { margin-bottom:1.5rem; }
.pref-label { font-size:11px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:.6rem; display:block; }
.tag-row { display:flex; flex-wrap:wrap; gap:8px; }
.tag { font-size:13px; padding:5px 14px; border-radius:99px; border:1px solid var(--border2); color:var(--muted); background:var(--bg3); cursor:default; }
.tag.active        { background:rgba(0,200,117,0.1);   border-color:rgba(0,200,117,0.35);   color:var(--green);  }
.tag.active-orange { background:rgba(255,160,50,0.1);  border-color:rgba(255,160,50,0.35);  color:var(--orange); }
.tag.active-blue   { background:rgba(79,163,224,0.1);  border-color:rgba(79,163,224,0.35);  color:var(--blue);   }
.salary-range { background:var(--bg3); border:1px solid var(--border2); border-radius:10px; padding:1rem; }
.salary-row { display:flex; justify-content:space-between; font-size:13px; color:var(--muted); margin-bottom:8px; }
.salary-row .val { color:var(--green); font-weight:500; }
.range-track { height:4px; background:var(--border2); border-radius:99px; position:relative; overflow:hidden; }
.range-fill { position:absolute; left:15%; width:60%; height:100%; background:var(--green); border-radius:99px; }

/* ── PROS / CONS ── */
.pros-cons-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.pros-box { background:rgba(0,200,117,0.05); border:1px solid rgba(0,200,117,0.2); border-radius:14px; padding:1.75rem; }
.cons-box { background:rgba(255,160,50,0.05); border:1px solid rgba(255,160,50,0.2); border-radius:14px; padding:1.75rem; }
.pros-box h3 { font-family:'Syne',sans-serif; font-weight:600; font-size:.95rem; color:var(--green); margin-bottom:1rem; }
.cons-box h3 { font-family:'Syne',sans-serif; font-weight:600; font-size:.95rem; color:var(--orange); margin-bottom:1rem; }
.pros-box ul,.cons-box ul { list-style:none; display:flex; flex-direction:column; gap:10px; }
.pros-box li,.cons-box li { font-size:14px; color:var(--muted); display:flex; align-items:flex-start; gap:10px; line-height:1.5; }
.pros-box li::before { content:''; width:16px; height:16px; border-radius:50%; flex-shrink:0; margin-top:1px; background:rgba(0,200,117,0.12) url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8l2.5 2.5L12 5' stroke='%2300c875' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center/contain; border:1px solid rgba(0,200,117,.3); }
.cons-box li::before { content:''; width:16px; height:16px; border-radius:50%; flex-shrink:0; margin-top:1px; background:rgba(255,160,50,0.1) url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8 5v4M8 11v.5' stroke='%23ffa032' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E") center/contain; border:1px solid rgba(255,160,50,.25); }

/* ── PRICING ── */
.pricing-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; align-items:start; }
.price-card { background:var(--bg2); border:1px solid var(--border2); border-radius:18px; padding:2rem; position:relative; transition:border-color .2s; }
.price-card:hover { border-color:var(--border); }
.price-card.featured { background:var(--bg3); border:1px solid rgba(0,200,117,.4); transform:scale(1.02); }
.price-card.featured:hover { transform:scale(1.03); }
.price-card.max-plan { background:linear-gradient(160deg,#162019 0%,#0e1912 100%); border:1px solid rgba(167,139,250,.3); }
.popular-tag { position:absolute; top:-13px; left:50%; transform:translateX(-50%); background:var(--green); color:#0a0f0d; font-size:11px; font-weight:700; padding:4px 16px; border-radius:99px; white-space:nowrap; font-family:'Syne',sans-serif; }
.max-tag { position:absolute; top:-13px; left:50%; transform:translateX(-50%); background:var(--purple); color:#fff; font-size:11px; font-weight:700; padding:4px 16px; border-radius:99px; white-space:nowrap; font-family:'Syne',sans-serif; }
.plan-name { font-family:'Syne',sans-serif; font-size:.8rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.1em; margin-bottom:.75rem; }
.plan-price { font-family:'Syne',sans-serif; font-size:3rem; font-weight:800; color:var(--text); line-height:1; }
.plan-price sup { font-size:1.2rem; vertical-align:super; }
.plan-price sub { font-size:.9rem; font-weight:400; color:var(--muted); vertical-align:baseline; }
.plan-trial { font-size:12px; color:var(--green); margin-top:6px; margin-bottom:1rem; font-weight:500; }
.plan-tagline { font-size:13px; color:var(--muted); line-height:1.5; margin-bottom:1.5rem; }
.plan-divider { height:1px; background:var(--border2); margin-bottom:1.5rem; }
.plan-compare { display:flex; flex-direction:column; gap:8px; margin-bottom:1.75rem; }
.plan-row { display:flex; align-items:flex-start; gap:10px; font-size:13px; color:var(--muted); line-height:1.5; }
.plan-row .ck { font-size:15px; line-height:1.4; flex-shrink:0; color:var(--green); }
.plan-row .ck-purple { color:var(--purple); }
.plan-row strong { color:var(--text); font-weight:500; }
.plan-row .sub-note { display:block; font-size:11px; color:rgba(122,153,128,.6); margin-top:1px; }
.plan-btn { width:100%; padding:13px; border-radius:10px; font-size:14px; font-weight:600; font-family:'DM Sans',sans-serif; cursor:pointer; text-align:center; display:block; transition:all .2s; }
.plan-btn-outline { background:transparent; border:1px solid var(--border2); color:var(--text); }
.plan-btn-outline:hover { border-color:var(--border); background:var(--surface); }
.plan-btn-filled { background:var(--green); border:none; color:#0a0f0d; }
.plan-btn-filled:hover { background:#00e688; box-shadow:0 4px 20px rgba(0,200,117,.35); }
.plan-btn-purple { background:var(--purple); border:none; color:#fff; }
.plan-btn-purple:hover { background:#b8a0ff; box-shadow:0 4px 20px rgba(167,139,250,.35); }
.price-note { font-size:12px; color:var(--muted); text-align:center; margin-top:1.25rem; }

/* ── COMPARE TABLE ── */
.compare-table-wrap { overflow-x:auto; border-radius:14px; border:1px solid var(--border2); margin-top:3rem; }
.compare-table { width:100%; border-collapse:collapse; font-size:14px; }
.compare-table th { padding:1rem 1.25rem; text-align:center; font-family:'Syne',sans-serif; font-size:.85rem; font-weight:600; background:var(--bg2); color:var(--muted); text-transform:uppercase; letter-spacing:.07em; border-bottom:1px solid var(--border2); }
.compare-table th.highlight { color:var(--green); background:var(--bg3); }
.compare-table th.highlight-purple { color:var(--purple); background:var(--bg3); }
.compare-table th:first-child { text-align:left; }
.compare-table td { padding:.9rem 1.25rem; text-align:center; color:var(--muted); border-bottom:1px solid var(--border2); }
.compare-table tr:last-child td { border-bottom:none; }
.compare-table td:first-child { text-align:left; color:var(--text); font-size:13px; }
.compare-table td.yes { color:var(--green); font-size:16px; }
.compare-table td.yes-purple { color:var(--purple); font-size:16px; }
.compare-table td.no { color:rgba(255,255,255,.1); font-size:16px; }
.compare-table tr:nth-child(even) td { background:rgba(255,255,255,.013); }

/* ── FAQ ── */
.faq-list { display:flex; flex-direction:column; gap:10px; }
.faq-item { background:var(--bg2); border:1px solid var(--border2); border-radius:12px; overflow:hidden; transition:border-color .2s; }
.faq-item:hover { border-color:var(--border); }
.faq-q { width:100%; display:flex; align-items:center; justify-content:space-between; padding:1.1rem 1.5rem; background:none; border:none; color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; cursor:pointer; text-align:left; gap:1rem; }
.faq-icon { font-size:18px; color:var(--muted); flex-shrink:0; transition:transform .25s; }
.faq-a { max-height:0; overflow:hidden; transition:max-height .3s ease; }
.faq-a-inner { padding:0 1.5rem 1.1rem; font-size:14px; color:var(--muted); line-height:1.7; }
.faq-item.open .faq-a { max-height:300px; }
.faq-item.open .faq-icon { transform:rotate(45deg); color:var(--green); }

/* ── CTA ── */
.cta-section { text-align:center; padding:6rem 2rem; max-width:700px; margin:0 auto; position:relative; z-index:1; }
.cta-glow { position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:500px; height:300px; background:radial-gradient(ellipse,rgba(0,200,117,.08) 0%,transparent 70%); pointer-events:none; }
.cta-section h2 { font-family:'Syne',sans-serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; margin-bottom:1rem; letter-spacing:-.01em; }
.cta-section p { color:var(--muted); margin-bottom:2rem; font-size:1.05rem; }
.cta-note { font-size:12px; color:var(--muted); margin-top:1rem; }

/* ── FOOTER ── */
footer { border-top:1px solid var(--border2); padding:2.5rem; text-align:center; font-size:13px; color:var(--muted); position:relative; z-index:1; }
footer a { color:var(--green); }
footer a:hover { text-decoration:underline; }

/* ── SCROLL REVEAL ── */
.reveal { opacity:0; transform:translateY(24px); transition:opacity .65s ease,transform .65s ease; }
.reveal.visible { opacity:1; transform:translateY(0); }

/* ── RESPONSIV ── */
@media (max-width:900px) {
  .pricing-grid { grid-template-columns:1fr; }
  .price-card.featured { transform:none; }
  .cv-setup { grid-template-columns:1fr; }
  .cv-right { position:static; }
}
@media (max-width:768px) {
  nav { padding:1rem 1.5rem; }
  .nav-links { display:none; }
  .hero { padding:7rem 1.5rem 3rem; }
  .hero-stats { gap:1.5rem; flex-wrap:wrap; justify-content:center; }
  .pros-cons-grid { grid-template-columns:1fr; }
  section { padding:4rem 1.5rem; }
  .steps { grid-template-columns:1fr; }
}
@media (max-width:480px) {
  .hero h1 { font-size:2.2rem; }
  .hero-actions { flex-direction:column; align-items:center; }
  .btn-primary,.btn-secondary { width:100%; justify-content:center; text-align:center; }
}
